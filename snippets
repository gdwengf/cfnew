/* ─── Router ───────────────────────────────────────────────────────── */
export default {
  async fetch(request, env, ctx) {
    ctx.passThroughOnException();
    const url = new URL(request.url);
    const region = regionForRequest(request);
    /* ✦ Public site endpoints ✦ */
    if (url.pathname === '/' || url.pathname === '/index.html') return landingPage(request);
    if (url.pathname === '/health' || url.pathname === '/api/status') {
      return new Response(JSON.stringify({ok:true,ts:new Date().toISOString(),region}),
        {headers:{'Content-Type':'application/json'}});
    }
    if (url.pathname === '/robots.txt') return new Response('User-agent: *\nDisallow: /admin\n',
      {headers:{'Content-Type':'text/plain'}});
    if (request.headers.get('Upgrade')?.toLowerCase() === 'websocket') {
      const fb = await _bestIP(region);
      return onWebSocketUpgrade(request, fb);
    }
    /* ✦ Subscription ✦ */
    if (request.method === 'GET' && url.pathname.length > 1 && url.pathname !== '/') {
      const segs = url.pathname.replace(/\/$/,'').split('/').filter(Boolean);
      if (segs[0] && isValidUUID(segs[0])) {
        if (segs[0] !== AUTH) return new Response('Forbidden', {status:403});
        if (segs[1] === 'sub') return subContent(segs[0], url);
        return subPage();
      }
    }
    return new Response('Not Found', {status:404});
  }
};
function regionForRequest(request) {
  try { const c = request.cf?.country; return CFG.regionMap[c] || 'HK'; }
  catch { return 'HK'; }
}
