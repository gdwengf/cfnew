/* ─── Proxy: Core ─────────────────────────────────────────────────── */
const ADDR_IPv4 = 1;
const ADDR_DOMAIN = 2;
const ADDR_IPv6 = 3;

async function onWebSocketUpgrade(request, fallbackAddr) {
  const wsPair = new WebSocketPair();
  const [client, server] = Object.values(wsPair);
  server.accept();

  let conn = { socket: null };
  let isDNS = false;
  const earlyData = request.headers.get('sec-websocket-protocol') || '';
  const readable = _makeStream(server, earlyData);

  readable.pipeTo(new WritableStream({
    async write(chunk) {
      if (isDNS) return _dnsForward(chunk, server, null);
      if (conn.socket) {
        const w = conn.socket.writable.getWriter();
        await w.write(chunk);
        w.releaseLock();
        return;
      }
      const p = _parseHeader(chunk);
      if (p.error) throw new Error(p.error);
      if (p.isUDP) {
        if (p.port === 53) { isDNS = true; } else throw new Error(ERR.udpDnsOnly);
      }
      const resp = new Uint8Array([p.version[0], 0]);
      if (isDNS) return _dnsForward(chunk.slice(p.dataOffset), server, resp);
      await _tcpForward(p.addrType, p.host, p.port, chunk.slice(p.dataOffset), server, resp, conn, fallbackAddr);
    }
  })).catch(e => console.error('stream:', e));

  return new Response(null, { status: 101, webSocket: client });
}

async function _tcpForward(type, host, port, data, ws, resp, conn, fb) {
  const connect = await __getConnect();

  async function doConnect(address, portNum) {
    const s = connect({ hostname: address, port: portNum });
    const w = s.writable.getWriter();
    await w.write(data);
    w.releaseLock();
    return s;
  }

  async function fallback() {
    let f = fb;
    if (!f) {
      const best = await _bestIP();
      if (best) f = best;
    }
    const p = parseAddr(f || host + ':' + port);
    const s = await doConnect(p.addr || host, p.port || port);
    conn.socket = s;
    s.closed.catch(() => {}).finally(() => _close(ws));
    _pipe(s, ws, resp, null);
  }

  try {
    const s = await doConnect(host, port);
    conn.socket = s;
    _pipe(s, ws, resp, fallback);
  } catch {
    fallback();
  }
}

function _parseHeader(chunk) {
  if (chunk.byteLength < 24) return { error: ERR.invalidData };
  const ver = new Uint8Array(chunk.slice(0, 1));
  const ident = _fmtId(new Uint8Array(chunk.slice(1, 17)));
  if (ident !== AUTH) return { error: ERR.invalidUser };
  const optLen = new Uint8Array(chunk.slice(17, 18))[0];
  const cmd = new Uint8Array(chunk.slice(18 + optLen, 19 + optLen))[0];
  if (cmd !== 1 && cmd !== 2) return { error: ERR.unsupportedCmd };
  const isUDP = cmd === 2;
  const pIdx = 19 + optLen;
  const port = new DataView(chunk.slice(pIdx, pIdx + 2)).getUint16(0);
  let aIdx = pIdx + 2, aLen = 0, vIdx = aIdx + 1, host = '';
  const addrType = new Uint8Array(chunk.slice(aIdx, vIdx))[0];
  switch (addrType) {
    case ADDR_IPv4: aLen = 4; host = new Uint8Array(chunk.slice(vIdx, vIdx + aLen)).join('.'); break;
    case ADDR_DOMAIN: aLen = new Uint8Array(chunk.slice(vIdx, vIdx + 1))[0]; vIdx += 1; host = new TextDecoder().decode(chunk.slice(vIdx, vIdx + aLen)); break;
    case ADDR_IPv6: aLen = 16; const p6=[]; const dv=new DataView(chunk.slice(vIdx, vIdx+aLen)); for (let i=0; i<8; i++) p6.push(dv.getUint16(i*2).toString(16)); host=p6.join(':'); break;
    default: return { error: ERR.invalidAddrType + ': ' + addrType };
  }
  if (!host) return { error: ERR.emptyAddr };
  return { error: null, addrType, port, host, isUDP, version: ver, dataOffset: vIdx + aLen };
}

function _makeStream(socket, early) {
  let cancelled = false;
  return new ReadableStream({
    start(ctrl) {
      socket.addEventListener('message', e => { if (!cancelled) ctrl.enqueue(e.data); });
      socket.addEventListener('close', () => { if (!cancelled) { _close(socket); ctrl.close(); } });
      socket.addEventListener('error', e => ctrl.error(e));
      const { data, error } = _b64Arr(early);
      if (error) ctrl.error(error);
      else if (data) ctrl.enqueue(data);
    },
    cancel() { cancelled = true; _close(socket); }
  });
}

async function _pipe(remote, ws, header, retry) {
  let h = header, hasData = false;
  await remote.readable.pipeTo(new WritableStream({
    async write(chunk, ctrl) {
      hasData = true;
      if (ws.readyState !== 1) ctrl.error(ERR.wsNotOpen);
      if (h) { ws.send(await new Blob([h, chunk]).arrayBuffer()); h = null; }
      else ws.send(chunk);
    }
  })).catch(e => { _close(ws); });
  if (!hasData && retry) retry();
}

async function _dnsForward(chunk, ws, resp) {
  try {
    const connect = await __getConnect();
    const s = connect({ hostname: '8.8.4.4', port: 53 });
    let h = resp;
    const w = s.writable.getWriter();
    await w.write(chunk);
    w.releaseLock();
    await s.readable.pipeTo(new WritableStream({
      async write(chunk2) {
        if (ws.readyState === 1) {
          if (h) { ws.send(await new Blob([h, chunk2]).arrayBuffer()); h = null; }
          else ws.send(chunk2);
        }
      }
    }));
  } catch (e) { console.error('dns:', e.message); }
}

/* ─── Subscription helpers ────────────────────────────────────────── */
function genLinks(list, uuid, domain) {
  const protocol = 'vless';
  const path = '/?ed=2048';
  return list.map(item => {
    const safeIP = item.ip.includes(':') ? '[' + item.ip + ']' : item.ip;
    const port = item.port || 443;
    const p = new URLSearchParams({
      encryption: 'none', security: 'tls',
      sni: domain, fp: 'randomized',
      type: 'ws', host: domain, path
    });
    const name = _e(item.name || item.ip);
    return `${protocol}://${uuid}@${safeIP}:${port}?${p.toString()}#${name}`;
  });
}

async function fetchGitHubIPs() {
  try {
    const r = await fetch(CFG.githubPreferredURL);
    if (!r.ok) return [];
    const text = await r.text();
    return text.trim().split('\n').filter(Boolean).map(line => {
      const m = line.match(/^([^:]+):(\d+)#(.*)$/);
      return m ? { ip: m[1], port: parseInt(m[2]), name: m[3].trim() || m[1] } : null;
    }).filter(Boolean);
  } catch { return []; }
}

