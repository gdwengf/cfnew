/* ─── Helpers ─────────────────────────────────────────────────────── */
function _close(s) {
  try { if (s.readyState === 1 || s.readyState === 2) s.close(); } catch {}
}

function _b64Arr(s) {
  if (!s) return { data: null };
  try {
    s = s.replace(/-/g, '+').replace(/_/g, '/');
    return { data: Uint8Array.from(atob(s), c => c.charCodeAt(0)).buffer };
  } catch (e) { return { error: e }; }
}

const _hex = Array.from({ length: 256 }, (_, i) => (i + 256).toString(16).slice(1));
function _fmtId(arr, off = 0) {
  const id = (
    _hex[arr[off]] + _hex[arr[off+1]] + _hex[arr[off+2]] + _hex[arr[off+3]] + '-' +
    _hex[arr[off+4]] + _hex[arr[off+5]] + '-' +
    _hex[arr[off+6]] + _hex[arr[off+7]] + '-' +
    _hex[arr[off+8]] + _hex[arr[off+9]] + '-' +
    _hex[arr[off+10]] + _hex[arr[off+11]] + _hex[arr[off+12]] + _hex[arr[off+13]] +
    _hex[arr[off+14]] + _hex[arr[off+15]]
  ).toLowerCase();
  if (!isValidUUID(id)) throw new TypeError(atob('U3RyaW5naWZpZWQgaWRlbnRpZmllciBpcyBpbnZhbGlk'));
  return id;
}

/* ─── Router ───────────────────────────────────────────────────────── */
export default {
  async fetch(request, env, ctx) {
    ctx.passThroughOnException();
    try {
      const url = new URL(request.url);
      const region = regionForRequest(request);
      const fallbackAddr = await _bestIP(region);

      /* ✦ Public site endpoints ✦ */
      if (url.pathname === '/' || url.pathname === '/index.html') {
        return landingPage(request);
      }
      if (url.pathname === '/health' || url.pathname === '/api/status') {
        const s = JSON.stringify({ ok: true, timestamp: new Date().toISOString(), region });
        return new Response(s, { headers: { 'Content-Type': 'application/json' } });
      }
      if (url.pathname === '/robots.txt') {
        return new Response('User-agent: *\nDisallow: /admin\n', { headers: { 'Content-Type': 'text/plain' } });
      }
      if (url.pathname === '/favicon.ico') {
        return new Response('', { status: 204 });
      }

      /* ✦ Upgrade: WebSocket proxy ✦ */
      if (request.headers.get('Upgrade')?.toLowerCase() === 'websocket') {
        return onWebSocketUpgrade(request, fallbackAddr);
      }

      /* ✦ Subscription endpoints ✦ */
      if (request.method === 'GET') {
        if (url.pathname.length > 1 && url.pathname !== '/') {
          const raw = url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
          const first = raw[0];
          const isSub = raw[1] === 'sub';

          if (isValidUUID(first)) {
            if (first !== AUTH) return new Response('Forbidden', { status: 403 });
            if (isSub) return subContent(first, url);
            return subPage();
          }
        }
      }

      return new Response('Not Found', { status: 404 });
    } catch (err) {
      return new Response(err.toString(), { status: 500 });
    }
  }
};
