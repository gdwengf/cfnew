/* ─── Proxy: Core ─────────────────────────────────────────────────── */
const ADDR_IPv4 = 1;
const ADDR_DOMAIN = 2;
const ADDR_IPv6 = 3;

async function onWebSocketUpgrade(request, fallbackAddr) {
  const wsPair = new WebSocketPair();
  const [client, server] = Object.values(wsPair);
  server.accept();
  let conn = { socket: null };
  let isDNS = false;
  const early = request.headers.get('sec-websocket-protocol') || '';
  const rd = _mkStream(server, early);
  rd.pipeTo(new WritableStream({
    async write(chunk) {
      if (isDNS) return _dnsFwd(chunk, server, null);
      if (conn.socket) {
        const w = conn.socket.writable.getWriter();
        await w.write(chunk); w.releaseLock(); return;
      }
      const p = _parseHdr(chunk);
      if (p.error) throw new Error(p.error);
      if (p.isUDP && p.port !== 53) throw new Error(ERR.udpDnsOnly);
      if (p.isUDP) { isDNS = true; }
      const hdr = new Uint8Array([p.ver[0], 0]);
      if (isDNS) return _dnsFwd(chunk.slice(p.off), server, hdr);
      await _tcpFwd(p.addrType, p.host, p.port, chunk.slice(p.off), server, hdr, conn, fallbackAddr);
    }
  })).catch(e => {});
  return new Response(null, { status: 101, webSocket: client });
}

async function _tcpFwd(type, host, port, data, ws, hdr, conn, fb) {
  const connect = await __getConnect();
  async function doconn(a, p) {
    const s = connect({ hostname: a, port: p });
    const w = s.writable.getWriter();
    await w.write(data); w.releaseLock(); return s;
  }
  async function fbFn() {
    let f = fb;
    if (!f) { const b = await _bestIP(); if (b) f = b; }
    const pa = _parseA(f || host + ':' + port);
    const s = await doconn(pa.addr || host, pa.port || port);
    conn.socket = s;
    s.closed.catch(()=>{}).finally(()=>_cl(ws));
    _pipe(s, ws, hdr, null);
  }
  try {
    const s = await doconn(host, port);
    conn.socket = s;
    _pipe(s, ws, hdr, fbFn);
  } catch { fbFn(); }
}

function _parseHdr(c) {
  if (c.byteLength < 24) return { error: ERR.invalidData };
  const ver = new Uint8Array(c.slice(0, 1));
  if (_fmtId(new Uint8Array(c.slice(1, 17))) !== AUTH) return { error: ERR.invalidUser };
  const ol = new Uint8Array(c.slice(17, 18))[0];
  const cmd = new Uint8Array(c.slice(18+ol, 19+ol))[0];
  if (cmd !== 1 && cmd !== 2) return { error: ERR.unsupportedCmd };
  const isUDP = cmd === 2;
  const pi = 19+ol;
  const port = new DataView(c.slice(pi, pi+2)).getUint16(0);
  let ai = pi+2, v = ai+1, host=''; const at = new Uint8Array(c.slice(ai, v))[0];
  switch(at) {
    case ADDR_IPv4: v; host=new Uint8Array(c.slice(v,v+4)).join('.'); break;
    case ADDR_DOMAIN: const l=new Uint8Array(c.slice(v,v+1))[0]; v+=1; host=new TextDecoder().decode(c.slice(v,v+l)); break;
    case ADDR_IPv6: host='::1'; break;
    default: return {error: ERR.invalidAddrType};
  }
  if (!host) return { error: ERR.emptyAddr };
  return { error: null, addrType: at, port, host, isUDP, ver, off: v };
}

function _mkStream(s, e) {
  let c = false; return new ReadableStream({
    start(ctrl) {
      s.addEventListener('message', ev => { if(!c) ctrl.enqueue(ev.data); });
      s.addEventListener('close', () => { if(!c) { _cl(s); ctrl.close(); } });
      s.addEventListener('error', e => ctrl.error(e));
      const d = _bA(e); if(d.err) ctrl.error(d.err); else if(d.d) ctrl.enqueue(d.d);
    },
    cancel() { c=true; _cl(s); }
  });
