    }));
  } catch(e) { console.error('dns:', e.message); }
}

/* ─── Subscription helpers ────────────────────────────────────────── */
function genLinks(list, uuid, domain) {
  return list.map(item => {
    const ip = item.ip.includes(':') ? '['+item.ip+']' : item.ip;
    const port = item.port || 443;
    const p = new URLSearchParams({
      encryption: 'none', security: 'tls', sni: domain,
      fp: 'randomized', type: 'ws', host: domain, path: '/?ed=2048'
    });
    return `vless://${uuid}@${ip}:${port}?${p.toString()}#${_e(item.name||item.ip)}`;
  });
}

async function fetchGitHubIPs() {
  try {
    const r = await fetch(CFG.githubPreferredURL);
    if (!r.ok) return [];
    const text = await r.text();
    return text.trim().split('\n').filter(Boolean).map(line => {
      const m = line.match(/^([^:]+):(\d+)#(.*)$/);
      return m ? { ip: m[1], port: parseInt(m[2]), name: m[3].trim()||m[1] } : null;
    }).filter(Boolean);
  } catch { return []; }
}

async function _bestIP(region) {
  if (region && CFG.ipPool[region]) return CFG.ipPool[region];
  return Object.values(CFG.ipPool)[0];
}

