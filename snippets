async function _pipe(r, ws, hdr, retry) {
  let h = hdr, hasD = false;
  await r.readable.pipeTo(new WritableStream({
    async write(chunk, ctrl) {
      hasD = true;
      if (ws.readyState !== 1) ctrl.error(ERR.wsNotOpen);
      if (h) { ws.send(await new Blob([h,chunk]).arrayBuffer()); h=null; }
      else ws.send(chunk);
    }
  })).catch(()=>_cl(ws));
  if (!hasD && retry) retry();
}

async function _dnsFwd(c, ws, r) {
  try {
    const connect = await __getConnect();
    const s = connect({ hostname: '8.8.4.4', port: 53 });
    let h = r;
    const w = s.writable.getWriter(); await w.write(c); w.releaseLock();
    await s.readable.pipeTo(new WritableStream({
      async write(x) {
        if (ws.readyState === 1) {
          if (h) { ws.send(await new Blob([h,x]).arrayBuffer()); h=null; }
          else ws.send(x);
