function uuidV4() {
  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
    const r = Math.random() * 16 | 0;
    return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
  });
}

function isValidUUID(s) {
  return /^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(s);
}

function parseAddr(input) {
  if (!input) return { addr: '', port: null };
  if (input.includes('[') && input.includes(']')) {
    const m = input.match(/^\[([^\]]+)\](?::(\d+))?$/);
    if (m) return { addr: m[1], port: m[2] ? parseInt(m[2]) : null };
  }
  const ci = input.lastIndexOf(':');
  if (ci > 0) {
    const addr = input.slice(0, ci);
    const port = parseInt(input.slice(ci + 1));
    if (!isNaN(port) && port > 0 && port <= 65535) return { addr, port };
  }
  return { addr: input, port: null };
}

function regionForRequest(request) {
  try {
    const c = request.cf?.country;
    return CFG.regionMap[c] || 'HK';
  } catch { return 'HK'; }
